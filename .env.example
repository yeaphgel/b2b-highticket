# Clover A-sales 销冠教练系统 环境配置

# ─── 基础配置 ─────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=clover-a-sales
APP_VERSION=1.0.0

# ─── 端口配置 ─────────────────────────────────────────────────
DASHBOARD_PORT=3000
API_PORT=3000
HERMES_PORT=3001
WEBHOOK_PORT=3002

# ─── 网络绑定配置 ─────────────────────────────────────────────
# HOST: 服务监听的网络接口
#   - localhost 或 127.0.0.1: 仅本地访问
#   - 0.0.0.0: 所有网络接口（推荐用于服务器部署）
#   - 特定IP: 仅该IP可访问
HOST=0.0.0.0

# ─── 嵌入模型配置 ─────────────────────────────────────────────
# 默认使用 Jina AI（免费额度充足，每月 1M tokens）
# 免费申请：https://jina.ai
EMBEDDING_PROVIDER=jina
JINA_API_KEY=your_jina_api_key_here
JINA_EMBEDDING_MODEL=jina-embeddings-v3

# ─── 可选：改用 Doubao 嵌入（国内，需付费）───────────────────
# EMBEDDING_PROVIDER=doubao
# ARK_API_KEY=your_ark_api_key_here
# DOUBAO_EMBEDDING_MODEL=doubao-embedding-large

# ─── 语言设置 ─────────────────────────────────────────────────
DEFAULT_LANGUAGE=zh-Hans
# 支持: zh-Hans, zh-Hant, en, ja, fr

# ─── 通知配置 (钉钉/Feishu) ─────────────────────────────────
DINGTALK_WEBHOOK=your_dingtalk_webhook_here
FEISHU_WEBHOOK=your_feishu_webhook_here

# ─── OpenClaw 集成配置 ────────────────────────────────────
OPENCLAW_SECRET=your_openclaw_secret
OPENCLAW_API_KEY=your_openclaw_api_key

# ─── Hermes 集成配置（仅服务模式需要）────────────────────────────────────
# Skill 模式安装无需配置以下两项，Hermes 直接调用脚本无需 Webhook 认证
# HERMES_API_KEY=your_hermes_api_key    # 服务模式：Hermes API 通信用
# HERMES_SECRET=your_hermes_secret      # 服务模式：Webhook 签名验证用

# ─── 第三方 Webhook 签名 ────────────────────────────────────
CALENDAR_SECRET=your_calendar_webhook_secret
EMAIL_SECRET=your_email_webhook_secret
SALESFORCE_SECRET=your_salesforce_webhook_secret

# ─── 日志配置 ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ─── 数据库/存储配置 ────────────────────────────────────────
DATA_DIR=./data
BACKUP_DIR=./backups

# ─── 可选: Hermes 高级配置 ────────────────────────────────────
# HERMES_TRANSCRIPTION_MODEL=speech-to-text-v1
# HERMES_LANGUAGE=zh-Hans
# HERMES_AUTO_TRANSLATE=true

# ─── 可选: AI 模型配置 (对接外部 AI) ────────────────────────────────────
# AI_PROVIDER=openai  # 可选: openai, anthropic, local
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
